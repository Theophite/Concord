# Python
__pycache__/
*.pyc

# Datasets (downloaded)
cifar_data/
nanogpt_data/
data/

# Model / optimizer checkpoints + resume state (large, regenerable)
*.pt
*.pt.tmp
*.tmp

# Figures (regenerable from the analysis scripts)
*.png

# Training logs (transient; the curated record is in SESSION_NOTES_*.md)
*.log

# Run-output dir (saved weights, logs, figures, sweep txt -- all regenerable)
compare_out/
# ignore dist/ CONTENTS (build artifacts) but keep the distilled winning-config
# deliverable tracked. dist/* (not dist/) so git still descends to find the exception.
dist/*
!dist/concord_winner/
